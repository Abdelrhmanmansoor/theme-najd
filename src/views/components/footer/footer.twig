{# ============================================================
   NAJD THEME — Footer Component (Layout Router)
   Routes to the selected footer style layout
   Supports: wokiee / classic / centered / minimal / columns / magazine
   ============================================================ #}

{% set footer_style = theme.settings.get('footer_style', 'wokiee') %}

<footer class="najd-footer najd-footer--{{ footer_style }}">

    {% if footer_style == 'wokiee' %}
        {% include 'components.footer.layouts.wokiee' %}
    {% elseif footer_style == 'centered' %}
        {% include 'components.footer.layouts.centered' %}
    {% elseif footer_style == 'minimal' %}
        {% include 'components.footer.layouts.minimal' %}
    {% elseif footer_style == 'columns' %}
        {% include 'components.footer.layouts.columns' %}
    {% elseif footer_style == 'magazine' %}
        {% include 'components.footer.layouts.magazine' %}
    {% else %}
        {% include 'components.footer.layouts.classic' %}
    {% endif %}

</footer>
