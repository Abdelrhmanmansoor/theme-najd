{# ============================================================
   Brand Logos — Wokiee Style
   Showcase brand/vendor logos in a grid or carousel
   ============================================================ #}

{% set title = component.title|default('Our Brands') %}
{% set subtitle = component.subtitle|default('') %}
{% set layout = component.layout|default('grid') %}
{% set brands = component.brands|default([]) %}

<section class="najd-block najd-block--brand-logos wokiee-brands">
    <div class="container">
        {% if title %}
            <div class="wokiee-brands__header">
                <h2 class="wokiee-brands__title">{{ title }}</h2>
                {% if subtitle %}
                    <p class="wokiee-brands__subtitle">{{ subtitle }}</p>
                {% endif %}
            </div>
        {% endif %}
        
        {% if layout == 'carousel' %}
            <salla-slider type="carousel" auto-play show-controls="false">
                <div slot="items">
                    {% for brand in brands %}
                        <div class="swiper-slide wokiee-brands__slide">
                            <a href="{{ brand.url|default('#') }}" class="wokiee-brands__link">
                                <img src="{{ brand.image }}" alt="{{ brand.name }}" class="wokiee-brands__logo">
                            </a>
                        </div>
                    {% endfor %}
                </div>
            </salla-slider>
        {% else %}
            <div class="wokiee-brands__grid">
                {% for brand in brands %}
                    <a href="{{ brand.url|default('#') }}" class="wokiee-brands__item">
                        <img src="{{ brand.image }}" alt="{{ brand.name }}" class="wokiee-brands__logo">
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>
